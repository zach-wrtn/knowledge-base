{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://zach-wrtn.github.io/knowledge-base/schemas/products/prd.schema.json",
  "title": "Product Overview (frontmatter only; body = product summary + active-PRD index)",
  "type": "object",
  "additionalProperties": false,
  "required": ["product", "status", "last_updated", "schema_version"],
  "properties": {
    "product":        { "enum": ["ai-webtoon", "free-tab", "preview-feature", "ugc-platform"] },
    "status":         { "enum": ["draft", "active", "archived"] },
    "owner":          { "type": "string" },
    "last_updated":   { "type": "string", "format": "date" },
    "related_sprints": {
      "type": "array",
      "items": { "type": "string", "pattern": "^[a-z0-9-]+$" }
    },
    "active_prds": {
      "type": "array",
      "description": "Notion page ids of active (진행 중) feature PRDs mirrored under products/active-prds/. Populated manually; must match basenames in that directory without dashes.",
      "items": { "type": "string", "pattern": "^[a-f0-9]{8}-[a-f0-9]{4}-[a-f0-9]{4}-[a-f0-9]{4}-[a-f0-9]{12}$" }
    },
    "schema_version": { "const": 1 }
  }
}
